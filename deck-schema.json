{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/auto-ppt-engine/deck-schema.json",
  "title": "Auto PPT Deck",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "deckTitle",
    "language",
    "audience",
    "scenario",
    "tone",
    "theme",
    "sourceDisplayMode",
    "slideCount",
    "needsSpeakerNotes",
    "assumptions",
    "slides"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "0.3.0",
      "description": "Deck schema version for forward compatibility"
    },
    "deckTitle": {
      "type": "string",
      "minLength": 1
    },
    "language": {
      "type": "string",
      "minLength": 2
    },
    "audience": {
      "type": "string"
    },
    "scenario": {
      "type": "string"
    },
    "tone": {
      "type": "string"
    },
    "theme": {
      "type": "string"
    },
    "template": {
      "type": "string",
      "description": "Path to a .pptx brand template file. When set, uses python-pptx renderer."
    },
    "_theme": {
      "type": "object",
      "description": "Resolved theme object injected by the Python backend. Not set by users directly."
    },
    "_nativeCharts": {
      "type": "boolean",
      "description": "When true, use native OOXML charts instead of chart.js PNG images."
    },
    "sourceDisplayMode": {
      "type": "string",
      "enum": [
        "hidden",
        "notes",
        "footnote",
        "appendix"
      ]
    },
    "slideCount": {
      "type": "integer",
      "minimum": 1,
      "maximum": 30
    },
    "needsSpeakerNotes": {
      "type": "boolean"
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "maxItems": 30,
      "items": {
        "$ref": "#/$defs/slide"
      }
    }
  },
  "$defs": {
    "visualObject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "image",
            "placeholder"
          ]
        },
        "path": {
          "type": "string",
          "description": "Local file path to an image (for type=image)"
        },
        "url": {
          "type": "string",
          "description": "URL to a remote image (for type=image)"
        },
        "prompt": {
          "type": "string",
          "description": "Generation prompt for external image agent (for type=placeholder)"
        },
        "alt": {
          "type": "string",
          "description": "Alt text description for the image"
        },
        "position": {
          "type": "string",
          "enum": [
            "right",
            "left",
            "full",
            "center"
          ],
          "description": "Preferred position on the slide"
        }
      }
    },
    "chartSeries": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "data"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "data": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "number"
          }
        }
      }
    },
    "chart": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "description": "Empty chart placeholder for non-chart slides",
          "required": ["type", "title", "categories", "series"],
          "properties": {
            "type": { "type": "string", "const": "" },
            "title": { "type": "string", "maxLength": 0 },
            "categories": { "type": "array", "maxItems": 0 },
            "series": { "type": "array", "maxItems": 0 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "description": "Fully populated chart with valid data",
          "required": ["type", "title", "categories", "series"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["bar", "line", "pie", "area"]
            },
            "title": {
              "type": "string",
              "minLength": 1
            },
            "categories": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string" }
            },
            "series": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/chartSeries" }
            }
          }
        }
      ]
    },
    "table": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "columns",
        "rows"
      ],
      "properties": {
        "columns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rows": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "type": [
                "string",
                "number",
                "boolean"
              ]
            }
          }
        }
      }
    },
    "slideSource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "type",
        "location",
        "trustLevel",
        "priority",
        "usedFor"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "location": {
          "type": "string",
          "minLength": 1
        },
        "trustLevel": {
          "type": "string"
        },
        "priority": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        },
        "citation": {
          "type": "string"
        },
        "usedFor": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "slide": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "page",
        "layout",
        "title",
        "subtitle",
        "objective",
        "bullets",
        "left",
        "right",
        "table",
        "chart",
        "visuals",
        "sources",
        "speakerNotes"
      ],
      "properties": {
        "page": {
          "type": "integer",
          "minimum": 1
        },
        "layout": {
          "type": "string",
          "enum": [
            "title",
            "agenda",
            "section",
            "bullet",
            "two-column",
            "comparison",
            "timeline",
            "process",
            "table",
            "chart",
            "quote",
            "summary",
            "closing",
            "kpi",
            "swot",
            "image-text",
            "funnel"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "subtitle": {
          "type": "string"
        },
        "objective": {
          "type": "string"
        },
        "bullets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "left": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "right": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "table": {
          "$ref": "#/$defs/table"
        },
        "chart": {
          "$ref": "#/$defs/chart"
        },
        "visuals": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "$ref": "#/$defs/visualObject"
              }
            ]
          }
        },
        "sources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/slideSource"
          }
        },
        "speakerNotes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "kpis": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "value": { "type": "string" },
              "delta": { "type": "string" }
            },
            "required": ["label", "value"]
          }
        },
        "quadrants": {
          "type": "object",
          "properties": {
            "strengths": { "type": "array", "items": { "type": "string" } },
            "weaknesses": { "type": "array", "items": { "type": "string" } },
            "opportunities": { "type": "array", "items": { "type": "string" } },
            "threats": { "type": "array", "items": { "type": "string" } }
          }
        },
        "imagePosition": {
          "type": "string",
          "enum": ["left", "right"]
        },
        "funnel": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "value": { "type": "string" }
            },
            "required": ["label"]
          }
        }
      }
    }
  }
}
