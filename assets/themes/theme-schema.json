{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Auto PPT Theme",
  "description": "Visual theme configuration for PPTX rendering. All color values are 6-digit hex without # prefix.",
  "type": "object",
  "required": ["name", "colors", "fonts"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Human-readable theme name"
    },
    "colors": {
      "type": "object",
      "required": ["primary", "secondary", "accent", "background", "slideBg", "text", "textLight", "textMuted", "headerBg", "border"],
      "properties": {
        "primary":    { "type": "string", "pattern": "^[0-9A-Fa-f]{6}$", "description": "Primary accent color (headings, shapes, data viz)" },
        "secondary":  { "type": "string", "pattern": "^[0-9A-Fa-f]{6}$", "description": "Secondary accent color" },
        "accent":     { "type": "string", "pattern": "^[0-9A-Fa-f]{6}$", "description": "Tertiary accent color" },
        "background": { "type": "string", "pattern": "^[0-9A-Fa-f]{6}$", "description": "Page/slide background" },
        "slideBg":    { "type": "string", "pattern": "^[0-9A-Fa-f]{6}$", "description": "Default slide background" },
        "text":       { "type": "string", "pattern": "^[0-9A-Fa-f]{6}$", "description": "Primary text color" },
        "textLight":  { "type": "string", "pattern": "^[0-9A-Fa-f]{6}$", "description": "Light text (on dark backgrounds)" },
        "textMuted":  { "type": "string", "pattern": "^[0-9A-Fa-f]{6}$", "description": "Muted/secondary text" },
        "headerBg":   { "type": "string", "pattern": "^[0-9A-Fa-f]{6}$", "description": "Table header / highlight background" },
        "border":     { "type": "string", "pattern": "^[0-9A-Fa-f]{6}$", "description": "Lines, borders, dividers" },
        "closingBg":  { "type": "string", "pattern": "^[0-9A-Fa-f]{6}$", "description": "Closing slide background" },
        "titleBg":    { "type": "string", "pattern": "^[0-9A-Fa-f]{6}$", "description": "Title slide background" }
      },
      "additionalProperties": false
    },
    "fonts": {
      "type": "object",
      "required": ["heading", "body"],
      "properties": {
        "heading": { "type": "string", "description": "Font stack for headings (comma-separated with CJK fallbacks)" },
        "body":    { "type": "string", "description": "Font stack for body text (comma-separated with CJK fallbacks)" }
      },
      "additionalProperties": false
    },
    "chartColors": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[0-9A-Fa-f]{6}$" },
      "minItems": 2,
      "description": "Color palette for data visualization (charts, KPIs)"
    }
  },
  "additionalProperties": false
}
